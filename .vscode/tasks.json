{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run ProtoQuery Desktop",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "${workspaceFolder}\\desktop_app.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run ProtoQuery MCP Server",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "${workspaceFolder}\\mcp_server.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "MCP_TRANSPORT": "streamable-http"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Run ProtoQuery UI",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "${workspaceFolder}\\run_ui.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
